APP_NAME=Edu Content Platform MVP
DATABASE_PATH=storage/app.db
EXPORT_DIR=storage/exports
AUDIO_DIR=storage/audio
VIDEO_DRAFT_DIR=storage/video_drafts
ASSET_LIBRARY_DIR=storage/asset_library
THUMBNAIL_DIR=storage/thumbnails
SOURCE_SAFETY_DIR=storage/source_safety
TRUST_REVIEW_DIR=storage/trust_reviews
LEARNING_OUTPUT_DIR=storage/learning_outputs
HANDOFF_DIR=storage/handoffs

# React/Vite dev server origins allowed to call FastAPI.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000,http://127.0.0.1:3000

# AI provider chain. Keep template last because it always works.
AI_PROVIDER_CHAIN=transformers,template

# Laptop-safe defaults. Enable Ollama later on another desktop.
USE_OLLAMA=false
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b
OLLAMA_TIMEOUT_SECONDS=30

# Transformers is optional and can be heavy. Keep disabled until you install torch/transformers.
USE_TRANSFORMERS=false
TRANSFORMERS_MODEL=distilgpt2
TRANSFORMERS_MAX_NEW_TOKENS=220

# Hosted API settings are placeholders for a future adapter.
# Keep API keys only in your local .env. Never commit real keys.
USE_HOSTED_LLM=false
HOSTED_LLM_PROVIDER=disabled
HOSTED_LLM_BASE_URL=
HOSTED_LLM_MODEL=
HOSTED_LLM_API_KEY=
HOSTED_LLM_TIMEOUT_SECONDS=60

# TTS/audio chain. Windows SAPI can work on Windows without Ollama.
# If speech generation is not available, manual_recording creates a recording guide.
TTS_PROVIDER_CHAIN=windows_sapi,manual_recording
USE_WINDOWS_SAPI_TTS=true
USE_PYTTSX3_TTS=false
TTS_VOICE_ID=default
TTS_RATE=165

FRONTEND_ASSET_VERSION=30

# Role-based login foundation. Default admin is created only when the database has no users.
# Change DEFAULT_ADMIN_PASSWORD in your local .env before using the app beyond local testing.
AUTH_REQUIRED=false
AUTH_TOKEN_TTL_HOURS=72
AUTH_COOKIE_NAME=edu_content_session
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=lax
AUTH_MAX_ACTIVE_SESSIONS_PER_USER=8
DEFAULT_ADMIN_NAME=Local Admin
DEFAULT_ADMIN_EMAIL=admin@example.com
DEFAULT_ADMIN_PASSWORD=ChangeMe123!

# Release/checklist reports are generated on demand; keep generated reports out of Git if saved locally.
RELEASE_REPORT_DIR=storage/release_reports
